    <script>(function() {
    "use strict";

    const M = {
        keysPath: "/api/sunny-keys",
        ajaxHeader: "X-Sunny-Req",
        ajaxValue: "sunny",
        defaultTtlMs: 8000,
        cacheSkewMs: 250,
        seedRetryDelayMs: 120,
        apiRetryDelayMs: 80,
    };

    const keySeedCache = new Map();

    function apiPath(input) {
        const raw = typeof input === "string" ? input : (input && input.url) || "";
        if (!raw) return "";
        const parsed = new URL(raw, window.location.origin);
        return parsed.pathname || "";
    }

    async function seedApiCookies(path, method) {
        const key = `${method}:${path}`;
        const now = Date.now();
        const cached = keySeedCache.get(key);
        if (cached && cached.expireAt > now + M.cacheSkewMs) {
            return;
        }

        const query = new URLSearchParams({ path, method }).toString();
        let res = await fetch(`${M.keysPath}?${query}`, {
            method: "GET",
            credentials: "same-origin",
            headers: {
                [M.ajaxHeader]: M.ajaxValue,
            },
            cache: "no-store",
        });
        if (!res.ok && res.status === 403) {
            await new Promise((resolve) => setTimeout(resolve, M.seedRetryDelayMs));
            res = await fetch(`${M.keysPath}?${query}`, {
                method: "GET",
                credentials: "same-origin",
                headers: {
                    [M.ajaxHeader]: M.ajaxValue,
                },
                cache: "no-store",
            });
        }
        if (!res.ok) {
            throw new Error("seed_failed");
        }

        let ttlMs = M.defaultTtlMs;
        try {
            const payload = await res.json();
            const ttlSeconds = Number((payload && payload.t) || 0);
            if (Number.isFinite(ttlSeconds) && ttlSeconds > 0) {
                ttlMs = ttlSeconds * 1000;
            }
        } catch (_err) {
            ttlMs = M.defaultTtlMs;
        }

        keySeedCache.set(key, { expireAt: now + ttlMs });
    }

    async function sFetch(input, init) {
        const options = init ? {...init } : {};
        const method = (options.method || "GET").toUpperCase();
        const path = apiPath(input);
        if (!path || !path.startsWith("/api/")) {
            throw new Error("api_path_required");
        }

        await seedApiCookies(path, method);
        const headers = new Headers(options.headers || {});
        headers.set(M.ajaxHeader, M.ajaxValue);
        options.method = method;
        options.headers = headers;
        options.credentials = options.credentials || "same-origin";
        let response = await fetch(input, options);
        if (method === "GET" && response.status === 403) {
            const cacheKey = `${method}:${path}`;
            keySeedCache.delete(cacheKey);
            await new Promise((resolve) => setTimeout(resolve, M.apiRetryDelayMs));
            await seedApiCookies(path, method);
            response = await fetch(input, options);
        }
        return response;
    }

    window.sFetch = sFetch;
    window.secureApiFetch = sFetch;
})();
</script>
    <script>
        let allBatches = [];

        async function loadBatches() {
            const grid = document.getElementById('batchesGrid');
            CourseUX.setSkeleton(grid, 8, 'grid');
            try {
                const res = await secureApiFetch('/api/batches');
                if (res.status === 401) {
                    CourseUX.setState(grid, {
                        type: 'warning',
                        title: 'Verification Needed',
                        message: 'Please complete verification. Redirecting to verify page.'
                    });
                    setTimeout(() => {
                        window.location.href = '/verify';
                    }, 800);
                    return;
                }
                if (res.status === 429) {
                    CourseUX.setState(grid, {
                        type: 'warning',
                        title: 'Rate Limit Active',
                        message: 'Too many requests right now. Try again in a few seconds.'
                    });
                    return;
                }
                if (!res.ok) {
                    throw new Error('batches api failed');
                }
                allBatches = await res.json();
                renderBatches(allBatches);
            } catch (e) {
                CourseUX.setState(grid, {
                    type: 'error',
                    title: 'Batches Could Not Load',
                    message: 'There was a network issue while loading batches. Please refresh.'
                });
            }
        }

        function isFav(id) {
            const favs = JSON.parse(localStorage.getItem('favouriteCourses') || '[]');
            return favs.some(f => String(f.id) === String(id));
        }

        function toggleFav(batch) {
            let favs = JSON.parse(localStorage.getItem('favouriteCourses') || '[]');
            const exists = favs.some(f => String(f.id) === String(batch.id));
            if (exists) {
                favs = favs.filter(f => String(f.id) !== String(batch.id));
            } else {
                favs.push(batch);
            }
            localStorage.setItem('favouriteCourses', JSON.stringify(favs));
            filterBatches();
        }

        function formatDate(dateStr) {
            if (!dateStr) return 'N/A';
            const date = new Date(dateStr);
            const options = {
                day: '2-digit',
                month: 'short',
                year: 'numeric'
            };
            return date.toLocaleDateString('en-GB', options).replace(/ /g, ' ');
        }

        function renderBatches(list) {
            const grid = document.getElementById('batchesGrid');
            grid.innerHTML = '';
            if (list.length === 0) {
                CourseUX.setState(grid, {
                    type: 'info',
                    title: 'No Batches Found',
                    message: 'Try another search keyword or check again later.'
                });
                return;
            }

            list.forEach(b => {
                const card = document.createElement('div');
                card.className = 'card';
                card.addEventListener('click', () => window.location = '/batch/' + b.id);

                const img = document.createElement('img');
                img.src = b.image_large || '';
                card.appendChild(img);

                const content = document.createElement('div');
                content.className = 'card-content';

                const h3 = document.createElement('h3');
                h3.textContent = b.title || '';

                const p = document.createElement('p');
                p.textContent = 'Start: ' + formatDate(b.start_at);

                const btn = document.createElement('button');
                btn.className = 'btn-fav' + (isFav(b.id) ? ' active' : '');
                btn.textContent = isFav(b.id) ? '★ Favorited' : '☆ Add to Favorites';
                btn.addEventListener('click', ev => {
                    ev.stopPropagation();
                    toggleFav(b);
                });

                content.appendChild(h3);
                content.appendChild(p);
                content.appendChild(btn);
                card.appendChild(content);
                grid.appendChild(card);
            });
        }

        function filterBatches() {
            const q = document.getElementById('search').value.toLowerCase();
            renderBatches(allBatches.filter(b => (b.title || '').toLowerCase().includes(q)));
        }

        window.addEventListener('DOMContentLoaded', loadBatches);
    </script>


